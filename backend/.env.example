# ------------------------------------------------------------------
# MongoDB Atlas — copy to .env and fill in your credentials
# Get this from: Atlas Dashboard > Connect > Drivers > Python
# ------------------------------------------------------------------
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

DB_NAME=career_guidance_db

# ------------------------------------------------------------------
# JWT — use a long random string (≥32 bytes). Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------------
JWT_SECRET_KEY=

# ------------------------------------------------------------------
# CORS — origins allowed to call the API (comma-separated, no *)
# Example: http://127.0.0.1:5500,http://localhost:5500
# ------------------------------------------------------------------
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# ------------------------------------------------------------------
# Flask
# ------------------------------------------------------------------
FLASK_DEBUG=true
